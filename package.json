{
  "name": "terminal-tab-status",
  "version": "1.0.1",
  "description": "Terminal tab title sync for AI CLI tools (OpenCode, GitLab Duo). Animated spinner while AI processes, checkmark when done, auto-clears on tab focus.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "terminal-tab-status": "scripts/cli.js"
  },
  "files": [
    "dist",
    "src/standalone-plugin.ts",
    "bin/active-terminal-tab.swift",
    "bin/duo-hook.cjs",
    "scripts"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "postinstall": "node scripts/postinstall.js"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "gitlab-duo",
    "duo-cli",
    "terminal",
    "tab-title",
    "jetbrains",
    "pycharm",
    "intellij",
    "spinner",
    "session"
  ],
  "author": "yaruchyk",
  "license": "MIT",
  "homepage": "https://gitlab.com/yaruchyk.o/terminal-tab-status",
  "bugs": {
    "url": "https://gitlab.com/yaruchyk.o/terminal-tab-status/-/issues"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "*"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.4.3",
    "@types/node": "^25.6.0",
    "typescript": "^5.7.0"
  },
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/yaruchyk.o/terminal-tab-status.git"
  },
  "engines": {
    "node": ">=18"
  },
  "os": [
    "darwin",
    "linux"
  ]
}
